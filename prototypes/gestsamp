class AppState:
    def __init__(self):
        self.scale_idx       = 0
        self.sound_idx       = 1
        self.drone_octave    = 1
        self.lead_octave     = 3
        self.show_scale_menu = False
        self.show_sound_menu = False
        self._pinch_was      = {}   # leading-edge pinch tracking per hand index

    @property
    def scale(self):
        return SCALES[SCALE_NAMES[self.scale_idx]]

    @property
    def scale_name(self):
        return SCALE_NAMES[self.scale_idx]

    @property
    def sound_name(self):
        return SOUND_NAMES[self.sound_idx]

app = AppState()


