FONT      = cv2.FONT_HERSHEY_SIMPLEX
C_PANEL   = (32,  32,  40)
C_ACCENT1 = (50, 140, 255)    # blue  (drone)  BGR
C_ACCENT2 = (50, 210, 130)    # green (lead)   BGR
C_TEXT    = (225, 225, 225)
C_DIM     = (100, 100, 110)
C_GREEN   = ( 60, 210,  80)
C_HOVER   = ( 55,  55,  70)
C_WHITE   = (255, 255, 255)
C_BG_BAR  = (20,  20,  26)

mouse_pos   = [0, 0]
mouse_click = [False]

def mouse_cb(event, x, y, flags, param):
    mouse_pos[0], mouse_pos[1] = x, y
    if event == cv2.EVENT_LBUTTONDOWN:
        mouse_click[0] = True

def draw_btn(frame, label, rect, active, hovered, accent):
    x1,y1,x2,y2 = rect
    bg = accent if active else (C_HOVER if hovered else C_PANEL)
    cv2.rectangle(frame, (x1,y1), (x2,y2), bg, -1, cv2.LINE_AA)
    cv2.rectangle(frame, (x1,y1), (x2,y2), accent if active else C_DIM, 1, cv2.LINE_AA)
    tw, th = cv2.getTextSize(label, FONT, 0.44, 1)[0]
    cv2.putText(frame, label,
                (x1 + (x2-x1-tw)//2, y1 + (y2-y1+th)//2),
                FONT, 0.44, C_BG_BAR if active else C_TEXT, 1, cv2.LINE_AA)

def build_rects(items, ax, ay, iw=160, ih=28):
    return [(ax, ay+i*(ih+2), ax+iw, ay+i*(ih+2)+ih) for i in range(len(items))]

def draw_dropdown(frame, items, rects, sel, accent):
    for i,(x1,y1,x2,y2) in enumerate(rects):
        hov = x1<=mouse_pos[0]<=x2 and y1<=mouse_pos[1]<=y2
        bg  = accent if i==sel else (C_HOVER if hov else C_PANEL)
        cv2.rectangle(frame,(x1,y1),(x2,y2),bg,-1,cv2.LINE_AA)
        cv2.rectangle(frame,(x1,y1),(x2,y2),accent if i==sel else C_DIM,1,cv2.LINE_AA)
        tw,th = cv2.getTextSize(items[i],FONT,0.43,1)[0]
        cv2.putText(frame,items[i],(x1+10,y1+(y2-y1+th)//2),FONT,0.43,
                    C_BG_BAR if i==sel else C_TEXT,1,cv2.LINE_AA)

def draw_volume_bar(frame, vol, cx, ytop, bh=120, bw=12):
    x1,x2 = cx-bw//2, cx+bw//2
    cv2.rectangle(frame,(x1,ytop),(x2,ytop+bh),C_PANEL,-1,cv2.LINE_AA)
    cv2.rectangle(frame,(x1,ytop),(x2,ytop+bh),C_DIM,1,cv2.LINE_AA)
    f = int(vol*bh)
    if f>0:
        cv2.rectangle(frame,(x1,ytop+bh-f),(x2,ytop+bh),C_GREEN,-1,cv2.LINE_AA)
    cv2.putText(frame,f"{int(vol*100)}%",(cx-14,ytop+bh+16),FONT,0.38,C_GREEN,1,cv2.LINE_AA)

def draw_hud(frame, w, h):
    with engine._lock:
        d_on,d_freq = engine.drone.on, engine.drone.freq
        l_on,l_freq = engine.lead.on,  engine.lead.freq
    by = h-54
    cv2.rectangle(frame,(0,by),(w,h),C_BG_BAR,-1,cv2.LINE_AA)
    cv2.line(frame,(0,by),(w,by),C_DIM,1,cv2.LINE_AA)

    dc = C_ACCENT1 if d_on else C_DIM
    lc = C_ACCENT2 if l_on else C_DIM
    cv2.putText(frame,f"DRONE  {freq_to_note_name(d_freq)}  {d_freq:.1f}Hz",(16,by+20),FONT,0.5,dc,1,cv2.LINE_AA)
    cv2.putText(frame,"● ON" if d_on else "○ OFF",(16,by+40),FONT,0.4,dc,1,cv2.LINE_AA)
    cv2.putText(frame,f"LEAD   {freq_to_note_name(l_freq)}  {l_freq:.1f}Hz",(w-300,by+20),FONT,0.5,lc,1,cv2.LINE_AA)
    cv2.putText(frame,"● ON" if l_on else "○ OFF",(w-300,by+40),FONT,0.4,lc,1,cv2.LINE_AA)

    cx=w//2
    cv2.putText(frame,f"Scale: {app.scale_name}",(cx-85,by+18),FONT,0.42,C_TEXT,1,cv2.LINE_AA)
    cv2.putText(frame,f"Sound: {app.sound_name}",(cx-85,by+38),FONT,0.42,C_TEXT,1,cv2.LINE_AA)

def draw_zones(frame, w, h):
    cv2.line(frame,(w//2,55),(w//2,h-57),(55,55,65),1,cv2.LINE_AA)
    cv2.putText(frame,"DRONE",(w//4-28,h-62),FONT,0.5,C_ACCENT1,1,cv2.LINE_AA)
    cv2.putText(frame,"LEAD" ,(3*w//4-22,h-62),FONT,0.5,C_ACCENT2,1,cv2.LINE_AA)
    cv2.putText(frame,f"Oct {app.drone_octave}",(w//4-18,72),FONT,0.38,C_ACCENT1,1,cv2.LINE_AA)
    cv2.putText(frame,f"Oct {app.lead_octave}" ,(3*w//4-18,72),FONT,0.38,C_ACCENT2,1,cv2.LINE_AA)

def draw_hints(frame, w, h):
    for i,txt in enumerate([
        "Z/X drone oct   C/V lead oct   S cycle scale   1-4 sound",
        "Left hand: open=play  fist=stop  pinch=set pitch",
        "Right hand: height = volume",
    ]):
        cv2.putText(frame,txt,(w//2-230,h-112-i*16),FONT,0.33,C_DIM,1,cv2.LINE_AA)

def draw_ring(frame, spread, cx, cy, color, on):
    r   = int(np.clip(spread*270,12,85))
    col = color if on else C_DIM
    cv2.circle(frame,(cx,cy),r,col,2 if on else 1,cv2.LINE_AA)
    if on:
        cv2.circle(frame,(cx,cy),5,color,-1,cv2.LINE_AA)


# ══════════════════════════════════════════════════════
#  6. MAIN LOOP
# ══════════════════════════════════════════════════════

cap = cv2.VideoCapture(0)
cap.set(cv2.CAP_PROP_FRAME_WIDTH,  1280)
cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 720)

WIN = "Gesture Synth"
cv2.namedWindow(WIN)
cv2.setMouseCallback(WIN, mouse_cb)

while cap.isOpened():
    ok, frame = cap.read()
    if not ok:
        break

    frame = cv2.flip(frame, 1)
    h, w  = frame.shape[:2]

    # Subtle dark overlay for legibility
    frame = cv2.addWeighted(frame, 0.76, np.zeros_like(frame), 0.24, 0)

    rgb     = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
    results = hands_detector.process(rgb)

    # Button geometry
    BTN_SCALE = (w//2-172, 8, w//2-8,  38)
    BTN_SOUND = (w//2+8,   8, w//2+172, 38)

    hov_s = BTN_SCALE[0]<=mouse_pos[0]<=BTN_SCALE[2] and BTN_SCALE[1]<=mouse_pos[1]<=BTN_SCALE[3]
    hov_d = BTN_SOUND[0]<=mouse_pos[0]<=BTN_SOUND[2] and BTN_SOUND[1]<=mouse_pos[1]<=BTN_SOUND[3]

    smr = build_rects(SCALE_NAMES, BTN_SCALE[0], BTN_SCALE[3]+4)
    snr = build_rects(SOUND_NAMES, BTN_SOUND[0], BTN_SOUND[3]+4, iw=145)

    # ── Mouse clicks ──
    if mouse_click[0]:
        mx, my = mouse_pos
        clicked_menu = False
        if BTN_SCALE[0]<=mx<=BTN_SCALE[2] and BTN_SCALE[1]<=my<=BTN_SCALE[3]:
            app.show_scale_menu = not app.show_scale_menu
            app.show_sound_menu = False
            clicked_menu = True
        elif BTN_SOUND[0]<=mx<=BTN_SOUND[2] and BTN_SOUND[1]<=my<=BTN_SOUND[3]:
            app.show_sound_menu = not app.show_sound_menu
            app.show_scale_menu = False
            clicked_menu = True
        elif app.show_scale_menu:
            for i,(x1,y1,x2,y2) in enumerate(smr):
                if x1<=mx<=x2 and y1<=my<=y2:
                    app.scale_idx = i
                    break
            app.show_scale_menu = False
            clicked_menu = True
        elif app.show_sound_menu:
            for i,(x1,y1,x2,y2) in enumerate(snr):
                if x1<=mx<=x2 and y1<=my<=y2:
                    app.sound_idx = i
                    engine.set(sound_idx=i)
                    break
            app.show_sound_menu = False
            clicked_menu = True
        if not clicked_menu:
            app.show_scale_menu = False
            app.show_sound_menu = False
        mouse_click[0] = False

    # ── Hands ──
    if results.multi_hand_landmarks and results.multi_handedness:
        for i, lms in enumerate(results.multi_hand_landmarks):
            # Swap labels (frame is flipped)
            raw   = results.multi_handedness[i].classification[0].label
            label = "Right" if raw == "Left" else "Left"

            pinch, spread, hx, hy = hand_metrics(lms)
            hx = ema(f"{i}_x", hx)
            hy = ema(f"{i}_y", hy)
            px, py = int(hx * w), int(hy * h)

            # ── RIGHT → volume ──────────────────────────────────
            if label == "Right":
                vol = float(np.clip(1.15 - hy * 1.3, 0.0, 1.0))
                vol = ema("vol", vol)
                engine.set(master_vol=vol)
                draw_volume_bar(frame, vol, px, max(10, py - 80))
                cv2.putText(frame,"VOL",(px-12, max(8, py-90)),FONT,0.38,C_GREEN,1,cv2.LINE_AA)

            # ── LEFT → pitch + trigger ──────────────────────────
            if label == "Left":
                is_drone = hx < 0.5
                accent   = C_ACCENT1 if is_drone else C_ACCENT2
                ok_key   = "drone_open" if is_drone else "lead_open"
                off_key  = "drone_fist" if is_drone else "lead_fist"
                on_key   = "drone_on"   if is_drone else "lead_on"
                fr_key   = "drone_freq" if is_drone else "lead_freq"

                # 1. Triggering (5-finger gesture)
                if timers[ok_key].update(spread > 0.20):
                    engine.set(**{on_key: True})
                if timers[off_key].update(spread < 0.10):
                    engine.set(**{on_key: False})

                # 2. Pitch Clutch (FIXED LOGIC)
                # Instead of 'if pinch and not was_pinch', we update AS LONG AS pinched.
                # This allows you to "scrub" through the notes until you find the right one.
                if pinch:
                    oct_ = app.drone_octave if is_drone else app.lead_octave
                    freq = y_to_freq(hy, app.scale, oct_)
                    engine.set(**{fr_key: freq})
                    
                    # Visual feedback for "Active Tuning"
                    cv2.circle(frame, (px, py), 22, C_WHITE, 2, cv2.LINE_AA)
                    cv2.putText(frame, "TUNING", (px + 25, py), FONT, 0.45, C_WHITE, 1)

                # Track state by hand label for stability
                app._pinch_was[label] = pinch

                # Visual feedback for the "Gate"
                with engine._lock:
                    cur_on = engine.drone.on if is_drone else engine.lead.on
                draw_ring(frame, spread, px, py, accent, cur_on)

            mp_draw.draw_landmarks(
                frame, lms, HAND_CONN,
                mp_draw.DrawingSpec(color=(170,170,200), thickness=1, circle_radius=2),
                mp_draw.DrawingSpec(color=(85,  85, 110), thickness=1),
            )

    # ── UI overlays ──
    draw_zones(frame, w, h)
    draw_hud(frame, w, h)
    draw_hints(frame, w, h)
    draw_btn(frame, f"◀ {app.scale_name} ▶", BTN_SCALE, app.show_scale_menu, hov_s, C_ACCENT1)
    draw_btn(frame, f"♪ {app.sound_name}",    BTN_SOUND, app.show_sound_menu, hov_d, C_ACCENT2)
    if app.show_scale_menu:
        draw_dropdown(frame, SCALE_NAMES, smr, app.scale_idx, C_ACCENT1)
    if app.show_sound_menu:
        draw_dropdown(frame, SOUND_NAMES, snr, app.sound_idx, C_ACCENT2)

    cv2.imshow(WIN, frame)

    # ── Keys ──
    key = cv2.waitKey(1) & 0xFF
    if key == 27:
        break
    elif key == ord('z'): app.drone_octave = max(0, app.drone_octave-1)
    elif key == ord('x'): app.drone_octave = min(5, app.drone_octave+1)
    elif key == ord('c'): app.lead_octave  = max(0, app.lead_octave -1)
    elif key == ord('v'): app.lead_octave  = min(5, app.lead_octave +1)
    elif key == ord('s'): app.scale_idx = (app.scale_idx+1) % len(SCALE_NAMES)
    elif ord('1') <= key <= ord('4'):
        idx = key - ord('1')
        app.sound_idx = idx
        engine.set(sound_idx=idx)

cap.release()
stream.stop()
cv2.destroyAllWindows()