"""
Gesture Synth — v3
==================
Controls
--------
  RIGHT hand  → volume  (raise hand = louder)
  LEFT  hand  → pitch + trigger
      left  half of frame  → DRONE voice
      right half of frame  → LEAD  voice
      open hand  (hold 0.4 s) → note ON
      fist       (hold 0.3 s) → note OFF
      pinch (thumb+index)     → latch pitch on first frame of pinch

Keyboard shortcuts
------------------
  ESC          quit
  Z / X        drone octave down / up
  C / V        lead  octave down / up
  1-4          select sound
  S            cycle scale

On-screen menus (click with mouse)
-----------------------------------
  [SCALE] button  top-centre
  [SOUND] button  top-centre (right of scale)
"""

import cv2
import mediapipe as mp
import numpy as np
import sounddevice as sd
import threading
import time

# ══════════════════════════════════════════════════════
#  1. SCALES & MUSIC THEORY
# ══════════════════════════════════════════════════════

SCALES = {
    "Pentatonic":    [0, 2, 4, 7, 9],
    "Major":         [0, 2, 4, 5, 7, 9, 11],
    "Natural Minor": [0, 2, 3, 5, 7, 8, 10],
    "Blues":         [0, 3, 5, 6, 7, 10],
    "Dorian":        [0, 2, 3, 5, 7, 9, 10],
    "Phrygian":      [0, 1, 3, 5, 7, 8, 10],
    "Lydian":        [0, 2, 4, 6, 7, 9, 11],
    "Mixolydian":    [0, 2, 4, 5, 7, 9, 10],
    "Chromatic":     list(range(12)),
}
SCALE_NAMES = list(SCALES.keys())
NOTE_NAMES  = ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"]
SOUND_NAMES = ["Sine", "Organ", "Soft Pad", "Pluck"]

C2_HZ = 65.406  # MIDI C2

def freq_to_note_name(freq):
    if freq <= 0:
        return "---"
    midi    = 12 * np.log2(freq / C2_HZ) + 24
    midi_i  = int(round(midi))
    return f"{NOTE_NAMES[midi_i % 12]}{midi_i // 12 - 1}"

def y_to_freq(y_norm, scale_semitones, octave_offset, n_octs=2):
    """Map y∈[0,1] (0=top) → snapped frequency."""
    sps   = len(scale_semitones)
    total = sps * n_octs
    step  = int(np.clip((1.0 - y_norm) * total, 0, total - 1))
    semi  = scale_semitones[step % sps] + (step // sps) * 12
    return C2_HZ * (2 ** ((semi + octave_offset * 12) / 12.0))


# ══════════════════════════════════════════════════════
#  2. AUDIO ENGINE
# ══════════════════════════════════════════════════════

SAMPLE_RATE = 44100
BLOCK_SIZE  = 256


def _smooth_env(cur, tgt, frames, k=0.004):
    """Vectorised exponential envelope — zero Python loops."""
    decay = np.exp(-k * np.arange(frames))
    env   = tgt + (cur - tgt) * decay
    return env, float(env[-1])


def _rich_wave(phases, freq):
    """Bandlimited odd-harmonic additive (warm organ)."""
    nyq = SAMPLE_RATE / 2
    sig = np.zeros(len(phases))
    h   = 1
    while freq * h < nyq:
        sig += (1.0 / h) * np.sin(h * phases)
        h   += 2
    return sig / (np.max(np.abs(sig)) + 1e-9)


class KarplusStrong:
    def __init__(self):
        self._buf    = np.zeros(4096)
        self._pos    = 0
        self._size   = 1
        self._active = False

    def trigger(self, freq):
        self._size  = max(1, int(SAMPLE_RATE / freq))
        self._buf   = (np.random.rand(self._size) * 2 - 1).astype(np.float64)
        self._pos   = 0
        self._active = True

    def release(self):
        self._active = False

    def generate(self, frames):
        out = np.zeros(frames)
        if not self._active:
            return out
        buf, pos, sz = self._buf, self._pos, self._size
        for i in range(frames):
            out[i]   = buf[pos]
            nxt      = (pos + 1) % sz
            buf[pos] = 0.996 * 0.5 * (buf[pos] + buf[nxt])
            pos      = nxt
        self._pos = pos
        return out


class Voice:
    def __init__(self):
        self.on      = False
        self.freq    = 130.81
        self._phase  = 0.0
        self._gain   = 0.0
        self._pad_g  = 0.0    # pad attack gain
        self._ks     = KarplusStrong()
        self._prev_on   = False

    def generate(self, frames, sound_idx):
        tgt = 1.0 if self.on else 0.0

        # ── Karplus-Strong (event driven) ──
        if sound_idx == 3:
            if self.on and not self._prev_on:
                self._ks.trigger(self.freq)
            if not self.on and self._prev_on:
                self._ks.release()
            self._prev_on = self.on
            return self._ks.generate(frames)

        # ── Soft pad (slow attack sine) ──
        if sound_idx == 2:
            inc    = 2 * np.pi * self.freq / SAMPLE_RATE
            t      = np.arange(frames)
            phases = self._phase + t * inc
            self._phase = float(phases[-1]) % (2 * np.pi)
            sig = np.sin(phases) + 0.3 * np.sin(2 * phases)
            env, self._pad_g = _smooth_env(self._pad_g, tgt, frames, k=0.0025)
            self._prev_on = self.on
            return sig * env

        # ── Sine / Organ (continuous phase) ──
        inc    = 2 * np.pi * self.freq / SAMPLE_RATE
        t      = np.arange(frames)
        phases = self._phase + t * inc
        self._phase = float(phases[-1]) % (2 * np.pi)

        sig = _rich_wave(phases, self.freq) if sound_idx == 1 else np.sin(phases)
        env, self._gain = _smooth_env(self._gain, tgt, frames)
        self._prev_on = self.on
        return sig * env


class AudioEngine:
    def __init__(self):
        self._lock      = threading.Lock()
        self.drone      = Voice()
        self.lead       = Voice()
        self.master_vol = 0.0
        self._vol_gain  = 0.0
        self.sound_idx  = 1

    def snapshot(self):
        with self._lock:
            return (self.drone.on, self.drone.freq,
                    self.lead.on,  self.lead.freq,
                    self.master_vol, self.sound_idx)

    def set(self, **kw):
        with self._lock:
            for k, v in kw.items():
                if   k == "drone_on":   self.drone.on    = v
                elif k == "drone_freq": self.drone.freq   = v
                elif k == "lead_on":    self.lead.on     = v
                elif k == "lead_freq":  self.lead.freq    = v
                else: setattr(self, k, v)

    def callback(self, outdata, frames, time_info, status):
        with self._lock:
            mv   = self.master_vol
            sidx = self.sound_idx
            d_sig = self.drone.generate(frames, sidx)
            l_sig = self.lead.generate(frames, sidx)

        v_env, self._vol_gain = _smooth_env(self._vol_gain, mv, frames, k=0.006)
        mixed = (d_sig * 0.45 + l_sig * 0.30) * v_env
        outdata[:] = np.clip(mixed, -1.0, 1.0).reshape(-1, 1)


engine = AudioEngine()
stream = sd.OutputStream(
    channels=1, callback=engine.callback,
    samplerate=SAMPLE_RATE, blocksize=BLOCK_SIZE, dtype="float32",
)
stream.start()


